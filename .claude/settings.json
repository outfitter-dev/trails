{
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(bun x *)",
      "Bash(gt *)",
      "Bash(gh *)",
      "Bash(oxlint *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(rg *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in *.md) bun run mdlint:fix \"$CLAUDE_FILE_PATH\" 2>/dev/null;; *) bun run format:file \"$CLAUDE_FILE_PATH\" 2>/dev/null;; esac; true",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}

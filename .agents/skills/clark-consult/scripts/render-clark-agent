#!/usr/bin/env bun

import { dirname, resolve } from "node:path";
import { fileURLToPath } from "node:url";

const scriptDir = dirname(fileURLToPath(import.meta.url));
const repoRoot = resolve(scriptDir, "../../../..");
const skillPath = resolve(repoRoot, ".agents/skills/clark/SKILL.md");
const agentPath = resolve(repoRoot, ".codex/agents/clark.toml");
const checkOnly = process.argv.includes("--check");

const codexConstraints = `## Codex Operational Constraints

- Do not run git or Graphite write operations. Do not run \`git add\`, \`git commit\`, \`git push\`, \`gt create\`, \`gt modify\`, \`gt submit\`, \`gt merge\`, or other source-control mutations.
- Make source-control recommendations to the parent agent instead.
- You may read files, inspect docs, run non-mutating searches, and append to \`.agents/memory/clark-decisions.md\` when logging an authoritative decision.
- Do not implement feature code unless the parent explicitly asks you to edit a decision artifact or review note.`;

function stripFrontmatter(markdown: string): string {
  if (!markdown.startsWith("---\n")) {
    return markdown.trim();
  }

  const end = markdown.indexOf("\n---\n", 4);
  if (end === -1) {
    throw new Error(`${skillPath} starts with frontmatter but has no closing delimiter`);
  }

  return markdown.slice(end + "\n---\n".length).trim();
}

const rawSkill = await Bun.file(skillPath).text();
const skillBody = stripFrontmatter(rawSkill);
const developerInstructions = `This Codex custom-agent wrapper is generated from \`.agents/skills/clark/SKILL.md\`, which is symlinked to the Claude Clark skill. Clark is skill-first: the skill is the canonical identity and judgment framework; this TOML exists only so Codex can delegate to Clark as a separate custom agent.

If this wrapper and the skill ever disagree, the skill wins. Regenerate this file with \`.agents/skills/clark-consult/scripts/render-clark-agent\`.

When the copied skill text names a Clark skill-local reference such as \`./references/assess.md\` or \`references/assess.md\`, resolve it relative to \`.agents/skills/clark/\`. When it says to load another Clark skill, read the matching \`.agents/skills/<skill-name>/SKILL.md\` symlink.

${skillBody}

${codexConstraints}`;

if (developerInstructions.includes("'''")) {
  throw new Error("Clark instructions contain TOML literal-string delimiter '''");
}

const toml = `# Generated by .agents/skills/clark-consult/scripts/render-clark-agent.
# Canonical Clark identity: .agents/skills/clark/SKILL.md

name = "clark"
description = "Co-architect and CTO of the Trails framework. Use for architectural decisions, vocabulary enforcement, sprint reviews, tenet alignment, and long-term framework coherence."
model = "gpt-5.5"
model_reasoning_effort = "xhigh"
sandbox_mode = "workspace-write"
nickname_candidates = ["Clark"]

developer_instructions = '''
${developerInstructions}
'''
`;

if (checkOnly) {
  let current: string;

  try {
    current = await Bun.file(agentPath).text();
  } catch (error) {
    if (error instanceof Error && "code" in error && error.code === "ENOENT") {
      console.error(
        [
          "Clark Codex custom-agent wrapper is missing.",
          "Run `bun run clark:sync` and commit the generated `.codex/agents/clark.toml`.",
        ].join("\n")
      );
      process.exit(1);
    }

    throw error;
  }

  if (current !== toml) {
    console.error(
      [
        "Clark Codex custom-agent wrapper is stale.",
        "Run `bun run clark:sync` and commit the regenerated `.codex/agents/clark.toml`.",
      ].join("\n")
    );
    process.exit(1);
  }

  console.log("Clark Codex custom-agent wrapper is up to date.");
} else {
  await Bun.write(agentPath, toml);
}

    "@ontrails/http": "workspace:^",
    "@ontrails/mcp": "workspace:^",
    "@ontrails/observability": "workspace:^",
    "@ontrails/store": "workspace:^",
    "@ontrails/tracing": "workspace:^",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ontrails/testing": "workspace:^"
  }
